# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
APP_NAME=gestio_backend
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Auth — access token lifetime (e.g. 7 days, 30 days, 12 hours)
AUTH_TOKEN_EXPIRES_IN=7 days

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# Database
#--------------------------------------------------------------------
# mysql required — migrations use MySQL syntax (tests also use mysql via .env.test)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=gestio

#--------------------------------------------------------------------
# Rate limiter (login brute-force protection)
#--------------------------------------------------------------------
# memory = in-process (local tests via .env.test), database = persisted (production)
LIMITER_STORE=database

#--------------------------------------------------------------------
# CORS (required in production — comma-separated frontend origins)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000